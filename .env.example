# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# RPC URLs per chain (required for Effect API calls: token metadata, oracle prices)
# dRPC example — swap YOUR_KEY for your actual key
